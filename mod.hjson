#the mod name as displayed in-game
displayName: "Mindustry Auto Sync"

#the internal name of your mod
name: "mas"

#your name
author: "ascpial"

#the fully qualified main class of the mod
main: "mas.MindustryAutomaticSync"

#the mod description as seen in the mod dialog
description: "Automatically export and import your save."

#the mod version
version: 0.1

#the minimum game build required to run this mod
minGameVersion: 154

#this is a java mod
java: true
